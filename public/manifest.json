{
    "manifest_version": 3,
    "name": "AI Credit Dashboard",
    "version": "1.0.0",
    "description": "Monitor your AI credits (OpenAI, x.ai, Moonshot, RunPod) in one place.",
    "action": {
        "default_popup": "index.html",
        "default_title": "AI Credit Dashboard"
    },
    "icons": {
        "16": "favicon.png",
        "48": "favicon.png",
        "128": "favicon.png"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://api.openai.com/*",
        "https://api.x.ai/*",
        "https://management-api.x.ai/*",
        "https://api.moonshot.cn/*",
        "https://api.moonshot.ai/*",
        "https://api.runpod.io/*"
    ]
}